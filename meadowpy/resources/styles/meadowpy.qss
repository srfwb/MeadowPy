/* MeadowPy IDE - Modern Light Theme Stylesheet */

* {
    font-family: "Segoe UI", "Arial", sans-serif;
}

QMainWindow {
    background-color: #F8F9FA;
}

QMainWindow::separator {
    width: 3px;
    height: 3px;
    background: #F0F0F0;
}

/* Tab Widget — Editor Tabs (V2) */
QTabWidget::pane {
    border: none;
    background: #FFFFFF;
    margin-top: -1px;
}

#editorContainer {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-radius: 10px;
}

QTabBar {
    background: #ECECEC;
    qproperty-drawBase: 0;
}

#editorTabs QTabBar {
    background: #ECECEC;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
}

/* Tabified dock-widget tab strips (Problems/Outline, Search/AI Chat, etc.) */
QMainWindow > QTabBar {
    background: #ECECEC;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
}

QTabBar::scroller {
    width: 0px;
}

QTabBar::tear {
    width: 0px;
    image: none;
}

QTabBar > QToolButton {
    background: #ECECEC;
    border: none;
    width: 0px;
    height: 0px;
    padding: 0px;
    margin: 0px;
}

QTabBar > QToolButton::left-arrow {
    image: none;
}

QTabBar > QToolButton::right-arrow {
    image: none;
}

QTabBar::tab {
    background: transparent;
    border: 1px solid transparent;
    border-bottom: none;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    padding: 4px 14px 8px 14px;
    min-width: 80px;
    color: #616161;
    font-size: 13px;
    margin-right: 2px;
}

QTabBar::tab:hover:!selected {
    background: #E4E4E4;
    color: #1F1F1F;
}

QTabBar::tab:selected {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom: none;
    border-top: 2px solid {{ACCENT}};
    color: #1F1F1F;
}


/* Toolbar */
QToolBar {
    background: #F8F9FA;
    border-bottom: 1px solid #DEE2E6;
    spacing: 4px;
    padding: 2px 4px;
}

QToolBar QToolButton {
    border: 1px solid transparent;
    border-radius: 4px;
    padding: 4px;
}

QToolBar QToolButton:hover {
    background: #E9ECEF;
    border-color: #CED4DA;
}

QToolBar QToolButton:pressed {
    background: #DEE2E6;
}

/* Run / Stop / Debug — disable default hover/press so only the glow shows */
QToolBar QToolButton#runButton:hover,
QToolBar QToolButton#runButton:pressed,
QToolBar QToolButton#stopButton:hover,
QToolBar QToolButton#stopButton:pressed,
QToolBar QToolButton#debugButton:hover,
QToolBar QToolButton#debugButton:pressed {
    background: transparent;
    border-color: transparent;
}

/* Status Bar */
QStatusBar {
    background: {{ACCENT}};
    color: white;
    border-top: none;
    min-height: 24px;
}

QStatusBar QLabel {
    color: white;
    padding: 0 8px;
    font-size: 12px;
}

QStatusBar::item {
    border: none;
}

/* Menu Bar */
QMenuBar {
    background: #F8F9FA;
    border-bottom: 1px solid #DEE2E6;
    padding: 0px;
}

QMenuBar::item {
    padding: 6px 10px;
    border-radius: 0px;
}

QMenuBar::item:selected {
    background: #E9ECEF;
}

/* Menus */
QMenu {
    background: #FFFFFF;
    border: 1px solid #DEE2E6;
    border-radius: 5px;
    padding: 4px;
}

QMenu[menubarMenu="true"] {
    border-top-left-radius: 0px;
    border-top-right-radius: 0px;
}

QMenu::item {
    padding: 6px 24px 6px 12px;
    border-radius: 3px;
}

QMenu::item:selected {
    background: #D4D4D4;
    color: #333333;
}

QMenu::separator {
    height: 1px;
    background: #DEE2E6;
    margin: 4px 8px;
}

/* Find/Replace Bar */
#FindReplaceBar {
    background: #F3F3F3;
    border: 1px solid #CCCCCC;
    border-radius: 6px;
    padding: 4px;
}

#FindReplaceBar QLineEdit {
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    padding: 4px 8px;
    background: #FFFFFF;
    font-size: 13px;
}

#FindReplaceBar QLineEdit:focus {
    border-color: {{ACCENT}};
}

#FindReplaceBar QPushButton {
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    padding: 4px 8px;
    background: #FFFFFF;
    font-size: 12px;
}

#FindReplaceBar QPushButton:hover {
    background: #E9ECEF;
}

#FindReplaceBar QPushButton:pressed {
    background: #DEE2E6;
}

#findToggleBtn {
    font-weight: bold;
    font-size: 11px;
}

#findToggleBtn:checked {
    background: {{ACCENT}};
    color: white;
    border-color: {{ACCENT_HOVER}};
}

/* Scrollbars — slim, modern overlay style */
QScrollBar:vertical {
    background: #FFFFFF;
    width: 10px;
    border: none;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: #C0C0C0;
    min-height: 40px;
    border-radius: 4px;
    margin: 1px;
}

QScrollBar::handle:vertical:hover {
    background: #A0A0A0;
}

QScrollBar::handle:vertical:pressed {
    background: #888888;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
    background: none;
    border: none;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
    border: none;
}

QScrollBar:horizontal {
    background: #FFFFFF;
    height: 10px;
    border: none;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background: #C0C0C0;
    min-width: 40px;
    border-radius: 4px;
    margin: 1px;
}

QScrollBar::handle:horizontal:hover {
    background: #A0A0A0;
}

QScrollBar::handle:horizontal:pressed {
    background: #888888;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
    background: none;
    border: none;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
    border: none;
}

/* ===== File Explorer Panel ===== */
#FileExplorer {
    background: #E5E7EB;
}

#explorerContainer {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
}

#explorerTitleBar {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom: none;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
}

#explorerTitleSeparator {
    background: #E5E7EB;
    border: none;
    max-height: 1px;
    min-height: 1px;
}

#explorerTitleLabel {
    color: #4B5563;
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 1px;
}

QToolButton#explorerTitleButton {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 4px;
    padding: 2px;
}

QToolButton#explorerTitleButton:hover {
    background: rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.10);
}

QToolButton#explorerTitleButton:pressed {
    background: rgba(0, 0, 0, 0.10);
}

QToolButton#explorerTitleButton::menu-indicator {
    image: none;
    width: 0;
    height: 0;
}

#explorerFolderRow {
    background: #FFFFFF;
    border: none;
}

/* #explorerProjectBadge is styled at runtime via apply_icon_theme() so
   its colors track the current accent (including custom themes). */

#explorerEmptyLabel {
    color: #999999;
    font-size: 12px;
    padding: 20px;
}

#explorerTree {
    background: #FFFFFF;
    border: none;
    font-size: 13px;
}

#explorerTree::item {
    padding: 4px 6px 4px 4px;
    border: none;
    border-left: 2px solid transparent;
    margin: 0px;
    outline: none;
}

#explorerTree:focus {
    outline: none;
}

#explorerTree::item:hover:!selected {
    background: rgba(0, 0, 0, 0.04);
    border-left: 2px solid rgba(0, 0, 0, 0.06);
}

#explorerTree::item:selected {
    background: rgba(0, 0, 0, 0.07);
    color: #1B1B1B;
    border-left: 2px solid {{ACCENT}};
}

#explorerTree::item:selected:!active {
    background: rgba(0, 0, 0, 0.05);
    color: #333333;
    border-left: 2px solid {{ACCENT}};
}

#explorerTree::branch:has-children:!has-siblings:closed,
#explorerTree::branch:closed:has-children:has-siblings {
    image: url({{ICONS_DIR}}/branch_closed_light.svg);
}

#explorerTree::branch:open:has-children:!has-siblings,
#explorerTree::branch:open:has-children:has-siblings {
    image: url({{ICONS_DIR}}/branch_open_light.svg);
}

/* Dock Widgets */
QDockWidget {
    color: #333333;
    titlebar-close-icon: none;
    titlebar-normal-icon: none;
}

QDockWidget::close-button,
QDockWidget::float-button {
    background: transparent;
    border: none;
    icon-size: 0px;
    padding: 0px;
    image: none;
}

/* Dialogs */
QDialog {
    background: #FFFFFF;
}

/* Colour picker — give the popup a light-grey background so the empty
   white Custom-Color cells are clearly outlined against it. */
QColorDialog {
    background: #DEDEDE;
}

#prefsCategory {
    background: #F8F9FA;
    border: 1px solid #DEE2E6;
    font-size: 13px;
    outline: none;
}

#prefsCategory::item {
    padding: 6px 10px;
    border-left: 3px solid transparent;
}

#prefsCategory::item:selected {
    background: #E8F0E8;
    color: #333333;
    border-left: 3px solid {{ACCENT}};
}

#prefsCategory::item:hover:!selected {
    background: #EEF1EE;
}

QPushButton {
    padding: 6px 16px;
    border: 1px solid #CCCCCC;
    border-radius: 4px;
    background: #FFFFFF;
    color: #333333;
    min-height: 24px;
    outline: none;
}

QPushButton:hover {
    background: #E9ECEF;
}

QPushButton:focus {
    border-color: {{ACCENT}};
}

QPushButton:pressed {
    background: #DEE2E6;
}

QDialogButtonBox QPushButton {
    min-width: 80px;
}

QDialogButtonBox QPushButton:default {
    background: {{ACCENT}};
    color: white;
    border-color: {{ACCENT_HOVER}};
}

QDialogButtonBox QPushButton:default:hover {
    background: {{ACCENT_HOVER}};
}

/* Global input styling */
QLineEdit {
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    padding: 4px 8px;
    background: #FFFFFF;
    color: #333333;
    min-height: 24px;
    selection-background-color: {{ACCENT}};
    selection-color: #FFFFFF;
}

QLineEdit:focus {
    border-color: {{ACCENT}};
}

/* Input widgets in preferences */
QSpinBox, QComboBox, QFontComboBox {
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    padding: 4px 8px;
    background: #FFFFFF;
    min-height: 24px;
}

QSpinBox:focus, QComboBox:focus, QFontComboBox:focus {
    border-color: {{ACCENT}};
}

QComboBox::drop-down {
    border: none;
    border-left: 1px solid #CCCCCC;
    width: 20px;
}

QComboBox::down-arrow {
    image: url({{ICONS_DIR}}/arrow_down_dark.svg);
    width: 10px;
    height: 10px;
}

QSpinBox::up-button, QSpinBox::down-button {
    background: #E9ECEF;
    border: none;
    border-left: 1px solid #CCCCCC;
    width: 20px;
}

QSpinBox::up-button {
    border-top-right-radius: 3px;
    border-bottom: 1px solid #CCCCCC;
}

QSpinBox::down-button {
    border-bottom-right-radius: 3px;
}

QSpinBox::up-button:hover, QSpinBox::down-button:hover {
    background: #DEE2E6;
}

QSpinBox::up-button:pressed, QSpinBox::down-button:pressed {
    background: {{ACCENT}};
}

QSpinBox::up-arrow {
    image: url({{ICONS_DIR}}/arrow_up_dark.svg);
    width: 10px;
    height: 10px;
}

QSpinBox::down-arrow {
    image: url({{ICONS_DIR}}/arrow_down_dark.svg);
    width: 10px;
    height: 10px;
}

QComboBox QAbstractItemView {
    background: #FFFFFF;
    border: 1px solid #DEE2E6;
    selection-background-color: {{ACCENT}};
    selection-color: #FFFFFF;
    outline: none;
}

QComboBox QAbstractItemView::item {
    padding: 4px 8px;
    border-left: 3px solid transparent;
    outline: none;
}

QComboBox QAbstractItemView::item:hover {
    background: #F0F4F0;
}

QComboBox QAbstractItemView::item:selected {
    background: {{ACCENT}};
    color: #FFFFFF;
    border-left: 3px solid {{ACCENT}};
}

QComboBox QAbstractItemView::item:focus {
    outline: none;
    border: none;
    border-left: 3px solid transparent;
}

QComboBox QAbstractItemView::item:selected:focus {
    border-left: 3px solid {{ACCENT}};
}

QCheckBox {
    spacing: 8px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    background: #FFFFFF;
}

QCheckBox::indicator:checked {
    background: {{ACCENT}};
    border-color: {{ACCENT_HOVER}};
}

QRadioButton {
    spacing: 8px;
    color: #212529;
}

QRadioButton::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid #CCCCCC;
    border-radius: 8px;
    background: #FFFFFF;
}

QRadioButton::indicator:checked {
    background: {{ACCENT}};
    border-color: {{ACCENT_HOVER}};
}

/* Symbol Outline Panel */
#SymbolOutline {
    background: #E5E7EB;  /* border-color matte so rounded corners blend */
}

#SymbolOutline QWidget {
    background: #FFFFFF;
    color: #1F2937;
}

#outlineTitleBar {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom: none;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
}

#outlineTitleLabel {
    color: #1F2937;
    font-size: 13px;
    font-weight: bold;
    background: transparent;
}

#outlineTitleSeparator {
    background: #E5E7EB;
    border: none;
    max-height: 1px;
    min-height: 1px;
}

#outlineContainer {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
}

#symbolTree {
    background: #FFFFFF;
    border: none;
    font-size: 13px;
}

#symbolTree::item {
    padding: 4px 6px 4px 4px;
    border: none;
    border-left: 2px solid transparent;
    margin: 0px;
    outline: none;
}

#symbolTree:focus {
    outline: none;
}

#symbolTree::item:hover:!selected {
    background: rgba(0, 0, 0, 0.04);
    border-left: 2px solid rgba(0, 0, 0, 0.06);
}

#symbolTree::item:selected {
    background: rgba(0, 0, 0, 0.07);
    border-left: 2px solid {{ACCENT}};
}

#symbolTree::item:selected:!active {
    background: rgba(0, 0, 0, 0.05);
    border-left: 2px solid {{ACCENT}};
}

#symbolTree::branch:has-children:!has-siblings:closed,
#symbolTree::branch:closed:has-children:has-siblings {
    image: url({{ICONS_DIR}}/branch_closed_light.svg);
}

#symbolTree::branch:open:has-children:!has-siblings,
#symbolTree::branch:open:has-children:has-siblings {
    image: url({{ICONS_DIR}}/branch_open_light.svg);
}

/* Problems Panel */
#ProblemsPanel {
    background: #E5E7EB;  /* border-color matte so rounded corners blend */
}

#ProblemsPanel QWidget {
    background: #FFFFFF;
    color: #1F2937;
}

#problemsTitleBar {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom: none;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
}

#problemsTitleLabel {
    color: #1F2937;
    font-size: 13px;
    font-weight: bold;
    background: transparent;
}

#problemsTitleSeparator {
    background: #E5E7EB;
    border: none;
    max-height: 1px;
    min-height: 1px;
}

#problemsContainer {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
}

#problemsTable {
    background: #FFFFFF;
    border: none;
    font-size: 12px;
    gridline-color: #F0F0F0;
}

#problemsTable::item {
    padding: 4px 6px 4px 4px;
    border: none;
    border-left: 2px solid transparent;
    outline: none;
}

#problemsTable:focus {
    outline: none;
}

#problemsTable::item:hover:!selected {
    background: rgba(0, 0, 0, 0.04);
    border-left: 2px solid rgba(0, 0, 0, 0.06);
}

#problemsTable::item:selected {
    background: rgba(0, 0, 0, 0.07);
    color: #1B1B1B;
    border-left: 2px solid {{ACCENT}};
}

#problemsTable::item:selected:!active {
    background: rgba(0, 0, 0, 0.05);
    color: #333333;
    border-left: 2px solid {{ACCENT}};
}

#problemsTable QHeaderView::section {
    background: #FFFFFF;
    border: none;
    border-bottom: 1px solid #E5E7EB;
    padding: 4px 8px;
    font-size: 11px;
    font-weight: bold;
}

/* ===== Watch Panel ===== */

#WatchPanel {
    background: #F8F9FA;
}

#WatchPanel QLineEdit {
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    padding: 4px 8px;
    background: #FFFFFF;
}

#WatchPanel QLineEdit:focus {
    border-color: #A0C0DD;
}

#WatchPanel QPushButton {
    background: #F0F0F0;
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    padding: 4px 8px;
}

#WatchPanel QPushButton:hover {
    background: #E0E0E0;
}

#watchTable {
    background: #FFFFFF;
    border: none;
    font-size: 13px;
    gridline-color: #F0F0F0;
}

#watchTable::item:selected {
    background: #E8F0FE;
    color: #333333;
}

#watchTable QHeaderView::section {
    background: #F5F5F5;
    border: none;
    border-bottom: 1px solid #DEE2E6;
    padding: 4px 8px;
    font-size: 11px;
    font-weight: bold;
}

/* ===== Call Stack Panel ===== */

#CallStackPanel {
    background: #F8F9FA;
}

#callStackList {
    background: #FFFFFF;
    border: none;
    font-size: 13px;
}

#callStackList::item {
    padding: 3px 4px;
    border-radius: 3px;
}

#callStackList::item:selected {
    background: #E8F0FE;
    color: #1A73E8;
}

#callStackList::item:hover:!selected {
    background: #F0F0F0;
}

/* ===== Variable Inspector Panel ===== */

#VariableInspector {
    background: #F8F9FA;
}

#variableTree {
    background: #FFFFFF;
    border: none;
    font-size: 13px;
}

#variableTree::item {
    padding: 3px 4px;
    border-radius: 3px;
}

#variableTree::item:selected {
    background: #E8F0FE;
    color: #1A73E8;
}

#variableTree::item:hover:!selected {
    background: #F0F0F0;
}

#variableTree QHeaderView::section {
    background: #F5F5F5;
    border: none;
    border-bottom: 1px solid #DEE2E6;
    padding: 4px 8px;
    font-size: 11px;
    font-weight: bold;
}

/* ===== Output Panel ===== */

#OutputPanel {
    background: #E5E7EB;  /* border-color matte so rounded corners blend */
}

#outputTitleBar {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom: none;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
}

#outputTitleLabel {
    color: #1F2937;
    font-size: 13px;
    font-weight: bold;
    background: transparent;
}

#outputTitleBar QLabel {
    color: #1F2937;
}

#outputTitleSeparator {
    background: #E5E7EB;
    border: none;
    max-height: 1px;
    min-height: 1px;
}

#outputContainer {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
}

#outputText {
    background: #FFFFFF;
    border: none;
    font-family: Consolas, "Courier New", monospace;
    font-size: 13px;
    color: #1E1E1E;
    padding: 4px;
}

#outputInputArea {
    background: #F0F0F0;
    border-top: 1px solid #DEE2E6;
}

#replPrompt {
    color: {{ACCENT}};
    font-weight: bold;
    font-family: Consolas, "Courier New", monospace;
    font-size: 13px;
}

#replRunBtn {
    background: {{ACCENT}};
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    padding: 4px 12px;
    font-weight: bold;
}

#replRunBtn:hover {
    background: {{ACCENT_HOVER}};
}

#outputInput {
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    padding: 4px 8px;
    background: #FFFFFF;
    font-family: Consolas, "Courier New", monospace;
    font-size: 13px;
}

#outputInput:focus {
    border-color: {{ACCENT}};
}

#outputFixAIBtn {
    background: #4A90D9;
    color: #FFFFFF;
    border: none;
    border-radius: 3px;
    padding: 2px 10px;
    font-size: 11px;
    font-weight: bold;
}

#outputFixAIBtn:hover {
    background: #5A9FE8;
}

/* ===== Welcome Screen ===== */

#WelcomeWidget {
    background: #FFFFFF;
}

#welcomeTitle {
    color: #333333;
}

#welcomeSubtitle {
    color: #888888;
}

#welcomeSectionLabel {
    color: #555555;
}

#welcomeActionBtn {
    background: #F0F0F0;
    border: 1px solid #CCCCCC;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 13px;
    color: #333333;
}

#welcomeActionBtn:hover {
    background: #E8F0E8;
    border-color: {{ACCENT}};
}

#welcomeTemplateCard {
    background: #F8F9FA;
    border: 1px solid #DEE2E6;
    border-radius: 8px;
}

#welcomeTemplateCard:hover {
    background: #E8F0E8;
    border-color: {{ACCENT}};
}

#welcomeCardTitle {
    color: #333333;
}

#welcomeCardDesc {
    color: #888888;
}

/* ===== Example Library Dialog ===== */

#ExampleLibraryDialog {
    background: #FFFFFF;
}

/* Header banner */
#exLibHeader {
    background: #F5F7FA;
}

#exLibTitle {
    color: #1A1A1A;
}

#exLibSubtitle {
    color: #888888;
}

#exLibSep {
    background: #DEE2E6;
    border: none;
}

#exLibVSep {
    background: #DEE2E6;
    border: none;
}

/* Sidebar */
#exLibSidebar {
    background: #F5F7FA;
}

#exLibCatHeader {
    color: #999999;
    letter-spacing: 1px;
}

/* Category buttons */
#exLibCatBtn {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
}

#exLibCatBtn:hover {
    background: #E8EDF2;
}

#exLibCatBtn[selected="true"] {
    background: #E8F0E8;
    border: 1px solid {{ACCENT}};
}

#exLibCatName {
    color: #333333;
}

#exLibCatBtn[selected="true"] #exLibCatName {
    color: {{ACCENT}};
}

#exLibCatCount {
    color: #999999;
}

/* Content area */
#exLibContent {
    background: #FFFFFF;
}

#exLibExamplesHeader {
    color: #1A1A1A;
}

/* Cards scroll area */
#exLibCardsScroll {
    background: transparent;
    border: none;
}

#exLibCardsWidget {
    background: transparent;
}

/* Example cards */
#exLibExCard {
    background: #FFFFFF;
    border: 1px solid #DEE2E6;
    border-radius: 8px;
    min-width: 160px;
    max-width: 200px;
}

#exLibExCard:hover {
    background: #F8F9FA;
    border-color: #B0B0B0;
}

#exLibExCard[selected="true"] {
    background: #F0F8F1;
    border: 1px solid {{ACCENT}};
}

#exLibExCardTitle {
    color: #333333;
}

#exLibExCard[selected="true"] #exLibExCardTitle {
    color: {{ACCENT}};
}

#exLibExCardDesc {
    color: #888888;
}

/* Preview area */
#exLibPreviewFrame {
    background: #FFFFFF;
}

#exLibPreviewBar {
    background: #F0F0F0;
    border: 1px solid #DEE2E6;
    border-bottom: none;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
}

#exLibPreviewTitle {
    color: #333333;
}

#exLibPreviewDesc {
    color: #888888;
}

#exLibCodePreview {
    background: #F8F9FA;
    border: 1px solid #DEE2E6;
    border-top: none;
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;
    font-family: Consolas, "Courier New", monospace;
    font-size: 13px;
    color: #1E1E1E;
    padding: 8px;
}

/* Footer */
#exLibFooter {
    background: #F5F7FA;
}

#exLibCountLabel {
    color: #999999;
}

#exLibOpenBtn {
    background: {{ACCENT}};
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 6px 18px;
    font-size: 13px;
    font-weight: bold;
}

#exLibOpenBtn:hover {
    background: {{ACCENT_HOVER}};
}

#exLibOpenBtn:disabled {
    background: #CCCCCC;
    color: #999999;
}

#exLibCloseBtn {
    background: #F0F0F0;
    border: 1px solid #CCCCCC;
    border-radius: 6px;
    padding: 6px 18px;
    font-size: 13px;
}

#exLibCloseBtn:hover {
    background: #E0E0E0;
}

/* ===== Search Panel ===== */

#SearchPanel {
    background: #E5E7EB;  /* border-color matte so rounded corners blend */
}

#SearchPanel QWidget {
    background: #FFFFFF;
    color: #1F2937;
}

#searchTitleBar {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom: none;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
}

#searchTitleLabel {
    color: #1F2937;
    font-size: 13px;
    font-weight: bold;
    background: transparent;
}

#searchTitleSeparator {
    background: #E5E7EB;
    border: none;
    max-height: 1px;
    min-height: 1px;
}

#searchContainer {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
}

/* Match the Output panel's input styling — higher specificity
   (#SearchPanel prefix) so it wins over the generic QLineEdit rule. */
#SearchPanel #searchInput {
    background: #FFFFFF;
    color: #212529;
    border: 1px solid #CED4DA;
    border-radius: 6px;
    padding: 4px 8px;
    font-size: 13px;
}

#SearchPanel #searchInput:focus {
    border-color: {{ACCENT}};
}

/* Accent-filled action button, matching the Output panel's Run button */
#SearchPanel #searchRunBtn {
    background: {{ACCENT}};
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 4px 14px;
    font-weight: bold;
    font-size: 13px;
}

#SearchPanel #searchRunBtn:hover {
    background: {{ACCENT_HOVER}};
}

#SearchPanel #searchRunBtn:disabled {
    background: #ADB5BD;
}

#SearchPanel QCheckBox {
    color: #1F2937;
    spacing: 4px;
    padding: 0;
    margin-top: 4px;
}

#SearchPanel QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 1px solid #CED4DA;
    border-radius: 4px;
    background: #FFFFFF;  /* match the input interior */
    subcontrol-position: center left;
}

#SearchPanel QCheckBox::indicator:hover {
    border-color: #9CA3AF;
}

#SearchPanel QCheckBox::indicator:checked {
    background: {{ACCENT}};
    border-color: {{ACCENT_HOVER}};
}

#SearchPanel QPushButton {
    background: #F0F0F0;
    color: #333333;
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    padding: 4px 12px;
}

#SearchPanel QPushButton:hover {
    background: #E0E0E0;
}

#SearchPanel QPushButton:pressed {
    background: {{ACCENT}};
    color: #FFFFFF;
    border-color: {{ACCENT_HOVER}};
}

#searchResultsTree {
    background: #FFFFFF;
    border: none;
    font-size: 13px;
}

#searchResultsTree::item {
    padding: 4px 6px 4px 4px;
    border: none;
    border-left: 2px solid transparent;
    margin: 0px;
    outline: none;
}

#searchResultsTree:focus {
    outline: none;
}

#searchResultsTree::item:hover:!selected {
    background: rgba(0, 0, 0, 0.04);
    border-left: 2px solid rgba(0, 0, 0, 0.06);
}

#searchResultsTree::item:selected {
    background: rgba(0, 0, 0, 0.07);
    color: #1B1B1B;
    border-left: 2px solid {{ACCENT}};
}

#searchResultsTree::item:selected:!active {
    background: rgba(0, 0, 0, 0.05);
    color: #333333;
    border-left: 2px solid {{ACCENT}};
}

#searchResultsTree::branch:has-children:!has-siblings:closed,
#searchResultsTree::branch:closed:has-children:has-siblings {
    image: url({{ICONS_DIR}}/branch_closed_light.svg);
}

#searchResultsTree::branch:open:has-children:!has-siblings,
#searchResultsTree::branch:open:has-children:has-siblings {
    image: url({{ICONS_DIR}}/branch_open_light.svg);
}

/* ===== Shortcut Reference Dialog v2 ===== */

#ShortcutReferenceDialog {
    background: #FFFFFF;
}

#shortcutTitle {
    color: #333333;
}

#shortcutSubtitle {
    color: #888888;
}

#shortcutSearch {
    background: #F8F9FA;
    border: 1px solid #DEE2E6;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 13px;
    color: #333333;
}

#shortcutSearch:focus {
    border-color: {{ACCENT}};
}

#shortcutScroll {
    background: transparent;
}

#shortcutContainer {
    background: transparent;
}

#shortcutCard {
    background: #FFFFFF;
    border: 1px solid #DEE2E6;
    border-radius: 8px;
}

#shortcutCardHeader {
    color: #333333;
    padding: 10px 14px 6px 14px;
}

#shortcutCardSep {
    background: #DEE2E6;
    margin-left: 28px;
    margin-right: 14px;
}

#shortcutRow {
    border-radius: 4px;
    margin: 1px 6px;
}

#shortcutRow:hover {
    background: #F5F7FA;
}

#shortcutActionLabel {
    color: #444444;
    font-size: 13px;
}

#shortcutKeyBadge {
    background: #F0F0F0;
    color: #333333;
    border: 1px solid #CCCCCC;
    border-bottom: 2px solid #BBBBBB;
    border-radius: 4px;
    padding: 2px 8px;
    font-family: "Consolas", monospace;
    font-size: 12px;
    min-width: 22px;
}

#shortcutKeyPlus {
    color: #999999;
    font-size: 12px;
}

#shortcutNoResults {
    color: #999999;
    font-size: 13px;
    padding: 20px;
}

#shortcutCloseBtn {
    background: #F0F0F0;
    border: 1px solid #CCCCCC;
    border-radius: 6px;
    padding: 6px 20px;
    font-size: 13px;
}

#shortcutCloseBtn:hover {
    background: #E0E0E0;
}

/* ===== Keyword Help Popup ===== */

#KeywordHelpPopup {
    background: #FFFFFF;
    border: 1px solid #CCCCCC;
    border-radius: 6px;
}

#kwHelpTitle {
    color: #1A73E8;
}

#kwHelpDesc {
    color: #333333;
}

#kwHelpExampleLabel {
    color: #555555;
}

#kwHelpCode {
    background: #F5F5F5;
    border: 1px solid #DEE2E6;
    border-radius: 4px;
    color: #1E1E1E;
    padding: 6px;
}

/* ===== Ollama / AI Status ===== */

#ollamaStatusLabel {
    padding: 0 8px;
    font-size: 12px;
}

#modelSelectorMenu {
    background: #FFFFFF;
    border: 1px solid #DEE2E6;
    border-radius: 5px;
    padding: 4px;
}

#modelSelectorMenu::item {
    padding: 6px 24px 6px 12px;
    border-radius: 3px;
}

#modelSelectorMenu::item:selected {
    background: #E8F0FE;
    color: #1A73E8;
}

#modelSelectorMenu::item:disabled {
    color: #999999;
}

#modelSelectorMenu::separator {
    height: 1px;
    background: #DEE2E6;
    margin: 4px 8px;
}

/* ===== AI Chat Panel ===== */

#AIChatPanel {
    background: #E5E7EB;  /* border-color matte so rounded corners blend */
}

#aiChatTitleBar {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom: none;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
}

#aiChatTitleSeparator {
    background: #E5E7EB;
    border: none;
    max-height: 1px;
    min-height: 1px;
}

#aiChatContainer {
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
}

#aiChatView, #aiChatViewInner {
    background: #FFFFFF;
    border: none;
}

#aiChatPlaceholder {
    color: #8A8A8A;
    font-size: 12px;
    padding: 10px;
}

#chatBubbleUser {
    background: {{ACCENT}};
    border-radius: 14px;
    color: #FFFFFF;
}

#chatBubbleUser QLabel {
    color: #FFFFFF;
    background: transparent;
}

#chatBubbleAi {
    background: #EDEDED;
    border-radius: 14px;
    color: #1F1F1F;
}

#chatBubbleAi QLabel {
    color: #1F1F1F;
    background: transparent;
}

#aiChatErrorLabel {
    color: #D32F2F;
    font-size: 12px;
    padding: 4px;
}

#aiChatStoppedLabel {
    color: #888888;
    font-size: 11px;
    padding: 2px;
}

#aiChatTitleLabel {
    font-weight: 600;
    color: #1F1F1F;
    font-size: 13px;
    letter-spacing: 0.2px;
}

#aiChatModelLabel {
    color: #6B6B6B;
    font-size: 11px;
}

#aiChatSetupBtn {
    background: #F0F3F1;
    border: 1px solid #CED4DA;
    border-radius: 4px;
    color: {{ACCENT}};
    font-size: 11px;
    font-weight: 600;
    padding: 1px 7px;
}

#aiChatSetupBtn:hover {
    background: #E4EAE6;
    border-color: {{ACCENT}};
}

#aiChatClearBtn {
    background: transparent;
    border: none;
    border-radius: 11px;
    color: #6B6B6B;
    font-size: 11px;
    padding: 0;
}

#aiChatClearBtn:hover {
    background: rgba(0, 0, 0, 0.06);
    color: #1F1F1F;
}

#aiChatInputContainer {
    background: #FFFFFF;
    border-top: 1px solid #DEE2E6;
}

#aiChatInput {
    background: #FFFFFF;
    border: 1px solid #CED4DA;
    border-radius: 6px;
    padding: 6px 8px;
    font-size: 13px;
    color: #212529;
}

#aiChatInput:focus {
    border-color: {{ACCENT}};
}

#aiChatSendBtn {
    background: {{ACCENT}};
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    font-weight: bold;
    font-size: 13px;
}

#aiChatSendBtn:hover {
    background: {{ACCENT_HOVER}};
}

#aiChatSendBtn:disabled {
    background: #ADB5BD;
}

#aiChatStopBtn {
    background: #D32F2F;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    font-weight: bold;
    font-size: 13px;
}

#aiChatStopBtn:hover {
    background: #B71C1C;
}

#aiChatStopBtn:disabled {
    background: #ADB5BD;
}

#aiChatHint {
    color: #999999;
    font-size: 11px;
}
